# ============================================================
# PhishScope v2.0 — Environment Configuration Example
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to Git.

# ── Flask Settings ──────────────────────────────────────────
FLASK_ENV=dev
# Must be a long random string in production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production

# Port to run the Flask server on
PORT=5000

# ── AI Provider Settings ────────────────────────────────────
# Currently only 'groq' is supported
AI_PROVIDER=groq

# Model name — do not change unless you know what you are doing
MODEL_NAME=llama-3.3-70b-versatile

# ── API Keys ─────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Upload Settings (Optional Overrides) ────────────────────
# Max upload file size in bytes (default: 10 MB)
# MAX_CONTENT_LENGTH=10485760
