# ============================================================
# PhishScope v2.0 — .gitignore
# ============================================================

# ── Python ──────────────────────────────────────────────────
backend/venv/
backend/__pycache__/
backend/app/__pycache__/
backend/app/api/__pycache__/
backend/app/models/__pycache__/
backend/app/services/__pycache__/
backend/app/utils/__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
*.egg

# ── Uploaded Files (temp) ────────────────────────────────────
backend/uploads/*.eml
backend/uploads/*.txt

# ── Node ─────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── Environment Secrets ──────────────────────────────────────
.env
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.production
*.env.local
*.env.production
*.env.development

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────
*.log
backend/logs/*.log

# ── Testing & Coverage ───────────────────────────────────────
.pytest_cache/
.mypy_cache/
htmlcov/
.coverage
coverage.xml

# ── Build Artifacts ──────────────────────────────────────────
build/
dist/